# Idle #
exec swayidle -w \
     timeout 3600 'swaylock; swaymsg "output * dpms off"; pactl set-source-mute @DEFAULT_SOURCE@ 1; pactl set-sink-mute @DEFAULT_SINK@ 1' \
	     resume 'swaymsg "output * dpms on"; pactl set-sink-mute @DEFAULT_SINK@ 0' \
     before-sleep 'swaylock; pactl set-source-mute @DEFAULT_SOURCE@ 1; pactl set-sink-mute @DEFAULT_SINK@ 1' \
     after-resume 'pactl set-sink-mute @DEFAULT_SINK@ 0' \
     lock 'swaylock; pactl set-source-mute @DEFAULT_SOURCE@ 1; pactl set-sink-mute @DEFAULT_SINK@ 1' \
     unlock 'pactl set-sink-mute @DEFAULT_SINK@ 0'

# Options #
focus_follows_mouse yes
focus_on_window_activation smart
hide_edge_borders --i3 smart
show_marks yes
floating_maximum_size -1 x -1

# Workspaces #
# Variables
set {
	$ws1 1
	$ws2 2
	$ws3 3
	$ws4 4
	$ws5 5
	$ws6 6
	$ws7 7
	$ws8 8
	$ws9 9
	$ws10 10
}

# Options
workspace_layout tabbed

# Assign workspaces to Displays
workspace {
	$ws1 output DP-1
	$ws2 output DP-2
	$ws3 output DP-1
	$ws4 output DP-2
	$ws5 output DP-1
	$ws6 output DP-2
	$ws7 output DP-1
	$ws8 output DP-2
	$ws9 output DP-1
	$ws10 output DP-2
}

# Keybinds #
# Variables
set {
	$W Mod4
	$A Mod1
	$C Control
	$S Shift
	$term alacritty
	$menu bemenu-run
}

# Binds
bindsym {
	$W+Return exec $term
	$W+r exec $menu
	$A+F12 exec powermenu

	$W+e exec notivol toggle
	XF86AudioRaiseVolume exec notivol vol +2%
	XF86AudioLowerVolume exec notivol vol -2%
	XF86AudioMute exec notivol vol 68%
	$C+F5 exec notivol vol 9830398%
	$A+F5 exec notivol vol 100%

	$W+t exec notidate
	$W+$A+t exec notidate America/New_York

	Print exec scr pic -c

	$W+c exec colorgrab -co
	$W+$A+c exec colorgrab -cn
	$W+$C+c exec colorgrab -cor
	$W+$C+$A+c exec colorgrab -cnr

	$W+space exec makoctl dismiss -a

	# change to focus next|prev next sway release
	$W+z focus right
	$W+$A+z focus left
	$W+$C+z focus mode_toggle

	$W+x move workspace to right
	$W+$A+x move workspace to left

	$W+Left focus left
	$W+Down focus down
	$W+Up focus up
	$W+Right focus right

	$W+1 workspace $ws1
	$W+2 workspace $ws2
	$W+3 workspace $ws3
	$W+4 workspace $ws4
	$W+5 workspace $ws5
	$W+6 workspace $ws6
	$W+7 workspace $ws7
	$W+8 workspace $ws8
	$W+9 workspace $ws9
	$W+0 workspace $ws10

	$W+$S+1 move container to workspace $ws1
	$W+$S+2 move container to workspace $ws2
	$W+$S+3 move container to workspace $ws3
	$W+$S+4 move container to workspace $ws4
	$W+$S+5 move container to workspace $ws5
	$W+$S+6 move container to workspace $ws6
	$W+$S+7 move container to workspace $ws7
	$W+$S+8 move container to workspace $ws8
	$W+$S+9 move container to workspace $ws9
	$W+$S+0 move container to workspace $ws10

	$W+$C+Escape exit
	$W+$A+Escape reload
	$W+q kill

	$W+$S+s floating enable
	$W+$S+t floating disable
	$W+$S+f fullscreen toggle
	$W+l layout toggle split tabbed
	$W+o layout toggle split
	$W+p splitt

	$W+d exec swaymsg seat seat0 hide_cursor 0
	$W+$A+d exec swaymsg seat seat0 hide_cursor 8000

	$W+v border normal 2
	$W+b border pixel 2
	$W+n border none
}

floating_modifier $W normal

# Window Rules #
for_window {
	# Make all windows float by default
	# According to `swaymsg -m "['window']" -t subscribe`, windows get their title after
	# they get created. However, app_id, class and instace are all set when the window is
	# created.
	[app_id="."] floating enable
	[class="."] floating enable
	[instance="."] floating enable

	# Make the title of each window bold
	[title="."] title_format "<b>%title</b>"

	[app_id="mpv"] border none

	# Set Alacritty's size. Doing this through Alacritty's config causes the window contents
	# to spill outside of the border when using multiple scaling factors and spawning
	# the terminal on one lower than the highest. Sets the terminal to 120x36.
	[app_id="Alacritty"] resize set width 976 px, resize set height 654 px

	# These apps should take up the entire screen and not have a border
	[app_id="firefox" title="^Mozilla Firefox$"] floating disable, border none
	[app_id="firefox" title=".*- Mozilla Firefox$"] floating disable, border none
	[app_id="firefox" title="^Firefox Nightly$"] floating disable, border none
	[app_id="firefox" title=".*- Firefox Nightly$"] floating disable, border none
