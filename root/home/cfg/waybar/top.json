{
	"layer":	   "top",
	"position":	   "top",
	"height":	   32,
	"modules-left":	   ["cpu", "memory"],
	"modules-center":  ["sway/workspaces"],
	"modules-right":   ["pulseaudio", "clock"],
	"name":		   "topbar",

	"clock": {
		"interval": 1,
		"format": "{:%R}",
		"timezones": [ "UTC", "America/New_York"],
		"tooltip-format": "{:%e %a %b %Y %Z}",
	},

	"cpu": {
		"interval": 2,
		"format": "CPU: {usage}%",
		"tooltip": false
	},

	"memory": {
		"interval": 2,
		"format": "RAM: {used:0.2f}G / {total:0.2f}G ({avail:0.2f}G)",
		"states": {
			"warn": 60,
			"crit": 80
		},
		"tooltip": false
	}

	"pulseaudio": {
		"format": "",
	}

	//"sway/workspaces": { }
}
