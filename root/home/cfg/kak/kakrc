# Load Plugin Manager
source "%val{config}/plugins/plug.kak/rc/plug.kak"

# Plugins
plug "whereswaldon/shellcheck.kak"
plug "andreyorst/smarttab.kak" defer smarttab %{
	set-option global smarttab_noexpandtab_mode_name 'Tab'
	set-option global smarttab_expandtab_mode_name 'Space'
	set-option global smarttab_smarttab_mode_name 'SmartTab'
} config %{
	# Use Tabs Only
	hook global WinSetOption filetype=(sh|i3|ini|kak|c) noexpandtab
	# Use Spaces Only
	hook global WinSetOption filetype=(css|html|xml|python) expandtab
	# Use Smart Tabs
	#hook global WinSetOption filetype=() smarttab
}

# kak-lsp
eval %sh{kak-lsp --kakoune -s $kak_session}
hook global WinSetOption filetype=(go|lua|python|rust) lsp-enable-window

# Template Command
define-command -params 1 -docstring \
"Print template into the current file. Templates are located at %val{config}/templates." \
template %{
	evaluate-commands %sh{
		[ -e "$kak_config/templates/$1" ] && \
			printf '%s\n' "exec !cat<space>$kak_config/templates/$1<ret>" || \
			printf '%s\n' "echo Template $1 doesn't exist."
	}
}

# Keybinds
map global user l ':enter-user-mode lsp<ret>' -docstring 'Enter kak-lsp user mode'
map global user p '!wl-paste<ret>' -docstring 'Paste from System Clipboard (Wayland)'
map global user y '<a-|>wl-copy<ret>' -docstring 'Copy to System Clipboard (Wayland)'

# Indention Widths
hook global WinSetOption filetype=(css|html|xml) %{ set-option global indentwidth 2 }
hook global WinSetOption filetype=python %{ set-option global indentwidth 4 }

# Enable Wrapping
add-highlighter global/ wrap -indent -marker '$>'

# Highlight Matching Characters
add-highlighter global/ show-matching

# Colorscheme
colorscheme theme
