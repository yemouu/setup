[colors]
bg_color = #efefef
fg_color = #1f1f1f

[bar/bar1]
width = 100%
height = 24

background = ${colors.bg_color}
foreground = ${colors.fg_color}

padding = 1
module-margin = 1

font-0 = monospace:size=10;2
font-1 = Noto Sans Mono:size=10;2
font-2 = Noto Sans Mono CJK JP:size=10;2
font-3 = Noto Sans Mono CJK TC:size=10;2
font-4 = Noto Sans Mono CJK SC:size=10;2
font-5 = Noto Sans Mono CJK KR:size=10;2
font-6 = Noto Color Emoji:scale=14;2

modules-left = music
modules-center = time
modules-right = powermenu

[module/time]
type = internal/date
interval = 1.0
time = %H:%M
date = %Y %b %a %d
format = <label>
label = " %date% %time% "

[module/music]
type = internal/mpd
interval = 1.0
label-song = " %artist% - %title% "
label-offline = " N/A "
format-playing = <label-song>
format-paused = <label-song>
format-stopped = " Music Stopped "
format-offline = <label-offline>

[module/powermenu]
type = custom/text
content = " Power Menu "
click-left = powermenu

