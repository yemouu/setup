#!/usr/bin/env bash

usage() {
	printf '%s\n' "usage: ${0##*/} [options]" \
	              "options:" \
	              "  -a: require confirmation to update and remove packages" \
	              "  -c: remove orphaned packages" \
	              "  -h: display usage statement" \
	              "  -l: skip rebuilding live packages" \
	              "  -r: regenerate ebuild cache" \
	              "  -s: skip repository sync" \
	              "  -u: update packages" \
	              "  -w: wait for intput before continuing"
}

info() {
	case $1 in
		f) msg="fail"; color="\e[31;1m";;
		i) msg="info"; color="\e[32;1m";;
		w) msg="warn"; color="\e[33;1m";;
	esac
	shift
	printf "${color}%s\e[m %s\n" "[${msg}]" "$*"
}

upd_wait() {
	[[ -z $upd_wait ]] && return 0
	while true
	do
		read -rp "Continue? [y/n] " input
		case $input in
			y ) break ;;
			n ) info f exiting...; exit 1 ;;
			* ) info w invalid option: "$input"; continue ;;
		esac
	done
}

remove_orphans() {
	info i removing orphans
	printf '%s\n' "$ sudo emerge --depclean --verbose $ask"
	sudo emerge --depclean --verbose "$ask" || \
		{ info f failed to remove orphans; exit 1; }
}

regen_cache() {
	info i regenerating ebuild cache
	printf '%s\n' "$ sudo emerge --regen --verbose"
	sudo emerge --regen --verbose || \
		{ info f failed to regenerate ebuild cache; exit 1; }
	upd_wait
}

sync_repo() {
	info i syncing repositories
	printf '%s\n' "$ sudo emaint sync --auto"
	sudo emaint sync --auto || { info f failed to sync repositories; exit 1; }
	upd_wait
}

update_pkgs() {
	info i updating packages
	printf '%s' "$ sudo emerge --update --deep --newuse --changed-deps " \
	            "--with-bdeps=y --verbose @world $ask"
	sudo emerge --update --deep --changed-deps --newuse --with-bdeps=y --verbose \
		@world "$ask" || { info f failed to update packages; exit 1; }
	[[ -n $upd_rebuild_live ]] || {
		printf '%s\n' "$ sudo emerge --oneshot @live-rebuild $ask"
		sudo emerge --oneshot @live-rebuild "$ask" || \
			{ info f failed to rebuild live packages; exit 1; }
	}
	upd_wait
}

command -v emerge &> /dev/null || { info f emerge not found; exit 1; }
command -v emaint &> /dev/null || { info f emaint not found; exit 1; }

[[ -z $* ]] && { sync_repo; exit 0; }
for (( a=1; a<$(( ${#@} + 1 )); a++ ))
do
	arg=${!a}
	[[ ! $arg =~ ^-.* || ${#arg} -lt 2 ]] && continue
	for (( i=1; i<${#arg}; i++ ))
	do
		case ${arg:$i:1} in
			a ) ask="--ask" ;;
			c ) upd_del_orphans=0 ;;
			h ) usage; exit 0 ;;
			l ) upd_rebuild_live=0 ;;
			r ) upd_regen_cache=0 ;;
			s ) upd_skip_sync_repos=1 ;;
			u ) upd_update_pkgs=0 ;;
			w ) upd_wait=0 ;;
			* ) printf '%s\n' "${0##*/}: -${arg:$i:1}: invalid argument"
			    usage; exit 1 ;;
		esac
	done
done

[[ -z $upd_skip_sync_repos ]] && sync_repo
[[ -n $upd_regen_cache ]] && regen_cache
[[ -n $upd_update_pkgs ]] && update_pkgs
[[ -n $upd_del_orphans ]] && remove_orphans
