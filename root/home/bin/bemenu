#!/bin/sh

. "${XDG_CACHE_HOME}/thm/colors.sh"
exec /usr/bin/bemenu -H 32 \
                     -i \
                     -m all \
                     -w \
                     --fn 'monospace 10' \
                     --fb "#${bg_color}" \
                     --ff "#${fg_color}" \
                     --hb "#${bg_color}" \
                     --hf "#${color2}" \
                     --nb "#${bg_color}" \
                     --nf "#${fg_color}" \
                     --tb "#${color1}" \
                     --tf "#${bg_color}" \
                     "$@"
