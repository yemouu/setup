#!/bin/sh

. "${XDG_CACHE_HOME}/thm/colors.sh"
exec /usr/bin/bemenu -i \
                     -w \
                     -m all \
                     -H 32 \
                     --fn "monospace 10" \
                     --tb="#$fg_color" \
                     --tf="#$color1" \
                     --fb="#$fg_color" \
                     --ff="#$color9" \
                     --nb="#$fg_color" \
                     --nf="#$color8" \
                     --hb="#$fg_color" \
                     --hf="#$bg_color" \
                     "$@"
