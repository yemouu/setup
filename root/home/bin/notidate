#!/bin/sh

# Required Commands:
# date - print current date
# notify-send - send notification

usage() {
    printf '%s\n' "usage: ${0##*/} [TIMEZONE]\n" \
	   "Availavle timezones can be found at" \
	   "/usr/share/zoneinfo/\n"
}

case $1 in
    -h|--help ) usage; exit 0 ;;
esac

[ -n "$1" ] && export TZ="$1"

app_name="Time and Date"
summary="$(date +'%R %d %a %b %Y %Z')"

notify-send -a "$app_name" \
	    -t 4000 \
	    "$summary"
