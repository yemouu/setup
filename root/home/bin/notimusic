#!/usr/bin/env bash

usage() {
    printf '%s\n' "usage: ${0##*/} action [seek_value|vol_value]" \
	   "action:" \
	   "  changed - display a notification when the song changes" \
	   "  info    - display a notification about mpd" \
	   "  seek    - seek and display a notification" \
	   "  toggle  - toggle state of mpd and display a notification" \
	   "  vol     - change mpd volume and display a notification\n"
}

m_changed() {
    app_name="MPD"
    summary="Now Playing"
    while pgrep mpd &> /dev/null
    do
	mpc current --wait &> /dev/null
	mp3art
	notify-send -a "$app_name" \
		    -t 4000 \
		    -i "$image" \
		    -u low \
		    "$summary" \
		    "$(mpc current)"
    done
}

m_info() {
    app_name="MPD Info"
    if ! mpc current
    then
	summary="[Stopped]"
    else
	mpc status | grep -q paused && playing="[Paused]"
	[[ $(mpc crossfade | awk '{print $2}') -gt 0 ]] && crossfade="x"
	[[ $(mpc status | awk NR==3'{print $4}') = "on" ]] && repeat="r"
	[[ $(mpc status | awk NR==3'{print $6}') = "on" ]] && random="z"
	[[ $(mpc status | awk NR==3'{print $8}') = "on" ]] && single="s"
	volume="$(mpc volume | sed 's/:/:\ /' | awk '{print $2}')"
	song_length="$(mpc | awk NR==2'{print $3}')"
	playlist_length="$(mpc listall | wc -l)"
	summary="[$playlist_length] [$repeat$random$single$crossfade] [$volume] [$song_length] $playing"
	body="$(mpc -q current)"
    fi
    
    notify-send -a "$app_name" \
		-t 4000 \
		-i "$image" \
		"$summary" \
		"$body"
}

m_seek() {
    app_name="MPD Seek"
    [[ $1 =~ [+-]?[0-9]?[0-9]% ]] && percentage="$1" || exit 1
    summary="$(mpc seek "$percentage" | awk NR==2'{print $3}') ($percentage)"
    body="$(mpc -q current)"

    notify-send -a "$app_name" \
		-t 4000 \
		-i "$image" \
		"$summary" \
		"$body"
}

m_toggle() {
    app_name="MPD Toggle"
    mpc toggle | grep -q paused && summary="Paused" || summary="Playing"

    notify-send -a "$app_name" \
		-t 4000 \
		-i "$image" \
		"$(mpc -q current) ($summary)"
}

m_vol() {
    app_name="MPD Volume"
    if [[ $1 =~ [+-]?[0-9]?[0-9] ]]
    then
	volume_change="$1"
	mpc -q volume "$volume_change"
	volume_final="$(mpc volume | sed 's/:/:\ /' | awk '{print $2}')"
	if [[ "${volume_change}%" = "$volume_final" ]]
	then
	    summary="$volume_final"
	else
	    summary="$volume_final ($volume_change)"
	fi
    else
	exit 1
    fi

    notify-send -a "$app_name" \
		-t 4000 \
		-i "$image" \
		"$summary"
}

image=$XDG_CACHE_HOME/mp3art.jpg

case $1 in
    "changed" ) m_changed          ;;
    "info"    ) m_info             ;;
    "seek"    ) shift; m_seek "$@" ;;
    "toggle"  ) m_toggle           ;;
    "vol"     ) shift; m_vol "$@"  ;;
    "*"       ) usage; exit 1      ;;
esac
