#!/usr/bin/env bash
# shellcheck disable=SC1090,SC2154

# SC1090 & SC2154
# The files sourced are user generated files that should contain the needed
# variables for the script to function correctly. It should be safe to ignore
# these warnings.

[[ -z $SCR_CFG_DIR ]] && SCR_CFG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/scr"
[[ -z $SCR_CACHE_DIR ]] && SCR_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/scr"
. "$SCR_CFG_DIR/config.sh" || \
	{ echo "${0##*/}: could not source $SCR_CONFIG_DIR/config.sh"; exit 1; }

usage() {
	printf '%s\n' "usage: ${0##*/} action [options]" \
	              "actions:" \
	              "  aud - audio" \
	              "  pic - picture" \
	              "  rec - record" \
	              "options:" \
	              "  -a - record desktop audio" \
	              "  -c - copy picture to clipboard" \
	              "  -h - display this message" \
	              "  -m - record microphone audio"
}

case $1 in
	aud   ) action="scr_aud" ;;
	pic   ) action="scr_pic" ;;
	rec   ) action="scr_rec" ;;
	*help ) usage; exit 0 ;;
	*     ) usage; exit 1 ;;
esac
shift

for (( a=1; a<$(( ${#@} + 1 )); a++ ))
do
	arg=${!a}
	[[ ! $arg =~ ^-.* || ${#arg} -lt 2 ]] && continue
	for (( i=1; i<${#arg}; i++ ))
	do
		case ${arg:$i:1} in
			a ) desktop_audio=true ;;
			c ) copy_clipboard=true ;;
			h ) usage; exit 0 ;;
			m ) microphone=true ;;
			* ) printf '%s\n' "${0##*/}: -${arg:$1:1}: invalid argument"
			    usage; exit 1 ;;
		esac
	done
done

die() {
	printf '%s\n' "${0##*/}: $*"
	exit 1
}

scr_aud() {
	[[ -d $scr_aud_dir ]] || \
		{ mkdir -p "$scr_aud_dir" || die "failed to make directory: $scr_aud_dir"; }

	[[ -d $SCR_CACHE_DIR ]] || \
		{ mkdir -p "$SCR_CACHE_DIR" || \
		  die "failed to make directory: $SCR_CACHE_DIR"; }

	filename="$scr_aud_dir/$aud_filename"

	[[ -z $microphone && -z $desktop_audio ]] && {
		die "aud: argument -a or -m is required to record audio" \
		    "run \`scr help\` for more information about arguments"
	}

	[[ -n $microphone ]] && { _args="-f pulse -i $aud_source"; }
	[[ -n $desktop_audio ]] && { _args="$_args -f pulse -i $aud_sink"; }
	[[ -n $microphone && -n $desktop_audio ]] && \
		{ _args="$_args -filter_complex amix=inputs=2"; }
	read -ra args <<< "$_args"

	ffmpeg "${args[@]}" "$filename" &> "$SCR_CACHE_DIR/aud.log"
	echo "$filename"
}

scr_pic() {
	[[ -d $scr_pic_dir ]] || \
		{ mkdir -p "$scr_pic_dir" || die "failed to make directory: $scr_pic_dir"; }

	[[ -d $SCR_CACHE_DIR ]] || \
		{ mkdir -p "$SCR_CACHE_DIR" || \
		  die "failed to create directory: $SCR_CACHE_DIR"; }

	filename="$scr_pic_dir/$pic_filename"

	read -r geom < <(slurp)
	pic_sel="-g-"

	printf '%s' "$geom" | grim "$pic_sel" "$filename" &> "$SCR_CACHE_DIR/pic.log"
	[[ -n $copy_clipboard ]] && \
		{ wl-copy  < "$filename" &> "$SCR_CACHE_DIR/copy.log"; }
	
	echo "$filename"
}

scr_rec() {
	[[ -d $scr_rec_dir ]] || \
		{ mkdir -p "$scr_rec_dir" || die "failed to make directory: $scr_pic_dir"; }

	[[ -e $SCR_CACHE_DIR/rec.pid ]] && \
		{ kill -15 "$(<"$SCR_CACHE_DIR/rec.pid")"
		  rm "$SCR_CACHE_DIR/rec.pid"; }

	[[ -d $SCR_CACHE_DIR ]] || \
		{ mkdir -p "$SCR_CACHE_DIR" || \
		  die "failed to make directory: $SCR_CACHE_DIR"; }

	filename="$scr_rec_dir/$rec_filename"

	read -r X Y W H < <(slurp -f "%x %y %w %h")
	rec_sel=""

	[[ -n $microphone && -n $desktop_audio ]] && {
		unload_pulse_modules=true
		pactlm_null_sink=$(pactl load-module module-null-sink sink_name=scr_inputs)
		pactlm_loopback1=$(pactl load-module module-loopback sink=scr_inputs source="$aud_sink")
		pactlm_loopback2=$(pactl load-module module-loopback sink=scr_inputs source="$aud_source")
		audio_args="-ascr_inputs.monitor"
	}

	[[ -n $microphone ]] && audio_args="-a$aud_source"
	[[ -n $desktop_audio ]] && audio_args="-a$aud_sink"
	read -ra args <<< "$rec_selection $audio_args"

	#wf-recorder "${args[@]}" -g "$(slurp)" -f "$filename" &> "$SCR_CACHE_DIR/rec.log"
	ffmpeg "${args[@]}" "$filename" &> "$SCR_CACHE_DIR/rec.log"

	echo "$filename"
}

$action
