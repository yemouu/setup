#!/usr/bin/env bash
# shellcheck disable=SC1090,SC2154

# SC1090 & SC2154
# The files sourced are user generated files that should contain the needed
# variables for the script to function correctly. It should be safe to ignore
# these warnings.

usage() {
	printf '%s\n' "usage: ${0##*/} theme"
}

hex2rgb() {
	hex=$1
	printf '%d,%d,%d' "0x${hex:0:2}" "0x${hex:2:2}" 0x"${hex:4:2}"
}

thm_config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/thm"
thm_dest_dir="${XDG_CACHE_HOME:-$HOME/.cache}/thm"

case $1 in
	-h|--help ) usage; exit 0 ;;
	"" )
		count=0
		files=("$thm_config_dir/themes/"*".theme")
		for f in "${files[@]}"
		do
			f=${f::-6}
			echo [$count] "${f/$thm_config_dir\/themes\//}"
			(( count++ ))
		done
		read -rp "Pick a theme: " theme_number
		! [[ $theme_number =~ [0-9]{1,} && $theme_number < $count ]] && \
			{ echo "${0##*/}: $theme_number: invalid theme number"; exit 1; }
		. "${files[theme_number]}"
		;;
	* )
		[[ ! -f "${thm_config_dir}/themes/${1}.theme" ]] && \
			{ echo "${0##*/}: $1: theme not found"; exit 1; }
		. "${thm_config_dir}/themes/${1}.theme"
		;;
esac

bg_color_rgb="$(hex2rgb "$bg_color")"
fg_color_rgb="$(hex2rgb "$fg_color")"
color0_rgb="$(hex2rgb "$color0")"
color1_rgb="$(hex2rgb "$color1")"
color2_rgb="$(hex2rgb "$color2")"
color3_rgb="$(hex2rgb "$color3")"
color4_rgb="$(hex2rgb "$color4")"
color5_rgb="$(hex2rgb "$color5")"
color6_rgb="$(hex2rgb "$color6")"
color7_rgb="$(hex2rgb "$color7")"
color8_rgb="$(hex2rgb "$color8")"
color9_rgb="$(hex2rgb "$color9")"
color10_rgb="$(hex2rgb "$color10")"
color11_rgb="$(hex2rgb "$color11")"
color12_rgb="$(hex2rgb "$color12")"
color13_rgb="$(hex2rgb "$color13")"
color14_rgb="$(hex2rgb "$color14")"
color15_rgb="$(hex2rgb "$color15")"

[[ ! -d $thm_dest_dir ]] && {
	mkdir -p "$thm_dest_dir" || {
		echo "${0##*/}: couldn't create $thm_dest_dir"; exit 1
	}
}

rm "$thm_dest_dir/"*

templates=("${thm_config_dir}/templates/"*"-template")
for t in "${templates[@]}"
do
	file_name=${t/${thm_config_dir}\/templates\//}
	file_name=${file_name/-template/}
	file="$(<"$t")"
	file="${file//\{bg_color\}/$bg_color}"
	file="${file//\{fg_color\}/$fg_color}"
	file="${file//\{color0\}/$color0}"
	file="${file//\{color1\}/$color1}"
	file="${file//\{color2\}/$color2}"
	file="${file//\{color3\}/$color3}"
	file="${file//\{color4\}/$color4}"
	file="${file//\{color5\}/$color5}"
	file="${file//\{color6\}/$color6}"
	file="${file//\{color7\}/$color7}"
	file="${file//\{color8\}/$color8}"
	file="${file//\{color9\}/$color9}"
	file="${file//\{color10\}/$color10}"
	file="${file//\{color11\}/$color11}"
	file="${file//\{color12\}/$color12}"
	file="${file//\{color13\}/$color13}"
	file="${file//\{color14\}/$color14}"
	file="${file//\{color15\}/$color15}"
	file="${file//\{bg_color.rgb\}/$bg_color_rgb}"
	file="${file//\{fg_color.rgb\}/$fg_color_rgb}"
	file="${file//\{color0.rgb\}/$color0_rgb}"
	file="${file//\{color1.rgb\}/$color1_rgb}"
	file="${file//\{color2.rgb\}/$color2_rgb}"
	file="${file//\{color3.rgb\}/$color3_rgb}"
	file="${file//\{color4.rgb\}/$color4_rgb}"
	file="${file//\{color5.rgb\}/$color5_rgb}"
	file="${file//\{color6.rgb\}/$color6_rgb}"
	file="${file//\{color7.rgb\}/$color7_rgb}"
	file="${file//\{color8.rgb\}/$color8_rgb}"
	file="${file//\{color9.rgb\}/$color9_rgb}"
	file="${file//\{color10.rgb\}/$color10_rgb}"
	file="${file//\{color11.rgb\}/$color11_rgb}"
	file="${file//\{color12.rgb\}/$color12_rgb}"
	file="${file//\{color13.rgb\}/$color13_rgb}"
	file="${file//\{color14.rgb\}/$color14_rgb}"
	file="${file//\{color15.rgb\}/$color15_rgb}"
	printf '%s\n' "$file" > "${thm_dest_dir}/${file_name}"
done

scripts=("${thm_config_dir}/scripts/"*)
for i in "${scripts[@]}"
do
	$i &> /dev/null &
done
