#!/usr/bin/env sh

app_name="Speakers"
summary="Volume: Increasing"

pactl set-sink-volume @DEFAULT_SINK@ +2%

if command -v dunstify
then
	dunstify -a "${app_name}" \
		-t 4000 \
		-r 13596705 \
		"${summary}" \
		"$(pactl list sinks | awk NR==10'{print $5}')"
elif command -v notify-send
then
	notify-send -t 4000 \
		-a "${app_name}" \
		"${summary}" \
		"$(pactl list sinks | awk NR==10'{print $5}')"
else
	echo "dunstify/notify-send not found"
	exit 1
fi
