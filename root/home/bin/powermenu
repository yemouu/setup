#!/usr/bin/env bash

[[ -z $BEMENU_OPTIONS ]] && BEMENU_OPTIONS="-i"

prompt="powermenu"
options="hibernate\\nhybrid-sleep\\nlock\\npoweroff\\nreboot\\nsuspend\\nsuspend-then-hibernate"

confirm() {
    c_prompt="Are you sure? [$action]"
    c_input=$(echo -e "yes\\nno" | bemenu $BEMENU_OPTIONS -p "$c_prompt")
    case $c_input in
	Y*|y* ) return 0 ;;
	N*|n* ) exit 0 ;;
	* ) exit 1 ;;
    esac
}

sleep_task() {
    pkill -USR1 swayidle
}

action=$(echo -e "$options" | bemenu $BEMENU_OPTIONS -p "$prompt")
case $action in
    hibernate ) confirm; alacritty -e systemctl hibernate ;;
    hybrid-sleep) confirm; alacritty -e systemctl hybrid-sleep ;;
    lock ) confirm; alacritty -e loginctl lock-session ;;
    poweroff ) confirm; alacritty -e systemctl poweroff ;;
    reboot ) confirm; alacritty -e systemctl reboot ;;
    suspend ) confirm; alacritty -e systemctl suspend ;;
    suspend-then-hibernate ) confirm; alacritty -e systemctl suspend-then-hibernate ;;
    * ) exit 1 ;;
esac
