#!/usr/bin/env bash

[[ -z $BEMENU_OPTIONS ]] && BEMENU_OPTIONS="-i"

prompt="powermenu"
options="display-off\\nhibernate\\nhybrid-sleep\\npoweroff\\nreboot\\nsuspend\\nsuspend-then-hibernate"

confirm() {
    c_prompt="Are you sure? [$action]"
    c_input=$(echo -e "yes\\nno" | bemenu $BEMENU_OPTIONS -p "$c_prompt")
    case $c_input in
	Y*|y* ) return 0 ;;
	N*|n* ) exit 0 ;;
	* ) exit 1 ;;
    esac
}

sleep_task() {
    mpc -q pause
    pactl set-source-mute @DEFAULT_SOURCE@ true
    pactl set-sink-mute @DEFAULT_SINK@ true
    while true
    do
	if [[ $(dunstify -b -t 0 -a "powermenu" "Speakers Muted" "Click here to unmute") = 2 ]]
	then
	    pactl set-sink-mute @DEFAULT_SINK@ false
	    exit 0
	fi
    done
}

display_off() {
    if [[ $XDG_SESSION_TYPE == "wayland" ]]
    then
	swayidle timeout 1 'swaymsg "output * dpms off"' \
		 resume 'swaymsg "output * dpms on"; pkill swayidle' &
    else
	xset dpms force off
    fi
}

action=$(echo -e "$options" | bemenu $BEMENU_OPTIONS -p "$prompt")
case $action in
    display-off ) confirm; sleep_task & sleep 0.5 && display_off ;;
    hibernate ) confirm; sleep_task & sleep 0.5 && alacritty -e systemctl hibernate ;;
    hybrid-sleep ) confirm; sleep_task & sleep 0.5 && alacritty -e systemctl hybrid-sleep ;;
    poweroff ) confirm; alacritty -e systemctl poweroff ;;
    reboot ) confirm; alacritty -e systemctl reboot ;;
    suspend ) confirm; sleep_task & sleep 0.5 && alacritty -e systemctl suspend ;;
    suspend-then-hibernate ) confirm; sleep_task & sleep 0.5 && alacritty -e systemctl suspend-then-hibernate ;;
    * ) exit 1 ;;
esac
