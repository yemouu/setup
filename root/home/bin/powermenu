#!/bin/sh

[ -z "$BEMENU_OPTIONS" ] && BEMENU_OPTIONS="-i"

prompt="powermenu"
options="hibernate\\nhybrid-sleep\\nlock\\npoweroff\\nreboot\\nsuspend\\nsuspend-then-hibernate"

confirm() {
    c_prompt="Are you sure? [$action]"
    c_input=$(printf '%b' "yes\\nno" | bemenu $BEMENU_OPTIONS -p "$c_prompt")
    case $c_input in
	Y*|y* ) return 0 ;;
	N*|n* ) exit 0 ;;
	* ) exit 1 ;;
    esac
}

sleep_task() {
    pkill -USR1 swayidle
}

action=$(printf '%b' "$options" | bemenu $BEMENU_OPTIONS -p "$prompt")
case $action in
    hibernate              ) confirm; alacritty -e loginctl hibernate ;;
    hybrid-sleep           ) confirm; alacritty -e loginctl hybrid-sleep ;;
    lock                   ) confirm; alacritty -e loginctl lock-session ;;
    poweroff               ) confirm; alacritty -e loginctl poweroff ;;
    reboot                 ) confirm; alacritty -e loginctl reboot ;;
    suspend                ) confirm; alacritty -e loginctl suspend ;;
    suspend-then-hibernate ) confirm; alacritty -e loginctl suspend-then-hibernate ;;
    *                      ) exit 1 ;;
esac
