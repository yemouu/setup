#!/usr/bin/env bash

# Set Environment variables
XDG_SESSION_TYPE=wayland
SDL_VIDEODRIVER=wayland
XDG_CURRENT_DESKTOP=Unity

export XDG_SESSION_TYPE SDL_VIDEODRIVER XDG_CURRENT_DESKTOP

# Autostart
{ pulseaudio --start &
  waybar & } &

# Pick Wayland Compositor
case $1 in
    sway|s ) exec dbus-launch --exit-with-session sway ;;
esac
