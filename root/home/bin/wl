#!/bin/sh

# Set Environment variables
XDG_SESSION_TYPE=wayland
SDL_VIDEODRIVER=wayland

export XDG_SESSION_TYPE SDL_VIDEODRIVER

# Autostart
{ pulseaudio --start & } &

# Pick Wayland Compositor
case $1 in
	sway|s    ) export XDG_CURRENT_DESKTOP=sway; exec dbus-launch --exit-with-session sway ;;
	hikari|h  ) exec dbus-launch --exit-with-session hikari ;;
	wayfire|w ) exec dbus-launch --exit-with-session wayfire ;;
esac
