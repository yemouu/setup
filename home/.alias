#!/usr/bin/env bash
alias l="ls -F --color=auto"
alias la="ls -A"
alias ll="ls -lh"
alias lla="ls -lAh"

alias c="clear"
alias cl="c;l"
alias cla="c;la"
alias cll="c;ll"
alias clla="c;lla"

alias suef="sudo -v;clear;sudo -u portage tail -f /var/log/emerge-fetch.log"
alias suel="sudo -v;clear;sudo -u portage tail -f /var/log/emerge.log"
alias sues="sudo -v;clear;sudo -Es"

alias em="sudo emerge"
alias emu="sudo emerge -uvDNa --with-bdeps=y @world"
alias emul="sudo emerge -a @live-rebuild"
alias qe="qlist -IR | grep -v ::gentoo"

alias e="nvim"
alias se="sudo -e"

alias gs="cd ${HOME}/.setup"
alias gc="cd ${HOME}/.config"

alias info="info --vi-keys"
alias q="exit"
alias sns="TERM=xterm-256color ssh -p 50769 yemou@owo"

run() {
	[[ $# -lt 2 ]] && return 1
	for ((i=1; i<=$1; i++))
	do
		"${@:2}"
	done
}

extract() {
	[[ ! -f $1 ]] && return 1
	for file in "$@"
	do
		case $file in
			*.tar*	) tar xvf "$file" ;;
			*.zip	) unzip "$file";;
			*	) echo ;;
		esac
	done
}
