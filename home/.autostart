#!/usr/bin/env bash

xorg_autostart() {
	[[ -f "${HOME}/.Xresources" ]] && xrdb -merge "${HOME}/.Xresources" &
	[[ -f "${HOME}/.config/thm/current/Xresources" ]] && xrdb -merge "${HOME}/.config/thm/current/Xresources" &
	xrandr -r 144 &
	setroot --restore &
	compton -b &
	blugon -f &
	start-pulseaudio-x11 &
	autostart &
	sxhkdm sxhkdm-default.sxhkdrc &
}

wayland_autostart() {
	autostart &
}

autostart() {
	! pgrep mpd && mpd &
	! pgrep syncthing && syncthing -no-browser &> /tmp/syncthing-autostart.log &
	"${HOME}/.setup/noti/music/music-changed" &
	parsecd app_daemon=1:app_silent=1:hidden=1 &
}

[[ $1 = "xorg" ]] && xorg_autostart &
[[ $1 = "wayland" ]] && wayland_autostart &
