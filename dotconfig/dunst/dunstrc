[global]
	monitor = 0
	follow = mouse
	geometry = "500x1-26-26"
	indicate_hidden = yes
	shrink = yes
	transparency = 0
	notification_height = 0
	separator_height = 2
	padding = 8
	horizontal_padding = 8
	frame_width = 6
	sort = no
	idle_threshold = 0
	font = Noto Sans 8
	line_height = 0
	markup = full
	format = "<b>%a</b>\n%s\n%b"
	alignment = left
	show_age_threshold = 60
	word_wrap = no
	ellipsize = middle
	ignore_newline = yes
	stack_duplicates = true
	hide_duplicate_count = false
	show_indicators = no
	icon_position = left
	max_icon_size = 44
	icon_path = /usr/share/icons/gnome/16x16/status/:/usr/share/icons/gnome/16x16/devices/
	sticky_history = yes
	history_length = 20
	dmenu = /usr/bin/rofi -dmenu
	browser = /usr/bin/firefox -new-tab
	always_run_script = true
	title = Dunst
	class = Dunst
	startup_notification = true
	force_xinerama = false

[experimental]
    per_monitor_dpi = false

[shortcuts]
    close = ctrl+space
    close_all = ctrl+shift+space
    history = ctrl+grave
    context = ctrl+shift+period

[urgency_low]
    timeout = 10

[urgency_normal]
    timeout = 10

[urgency_critical]
    timeout = 0

# vim: ft=cfg
