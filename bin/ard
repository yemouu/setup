#!/usr/bin/env bash

# Script for downloading mulitple files at once
# Requires
#	aria2

DIR="$(pwd)"
LINK=""
CONNECTIONS=""

usage(){
printf '%s' " 
Usage: ard [OPTIONS] -l [LINK]

Options:
	-h	displays this message

	-d	directory to download to

	-l	link to download

	-c	maximum number of connections to a server

"
}

get_args() {
	while getopts "d:l:hc:" OPTIONS
	do
		case  "${OPTIONS}" in
			"h"	)	usage;exit 0		;;
			"d"	)	DIR="${OPTARG}"		;;
			"l"	)	LINK="${OPTARG}"	;;
			"c"	)	CONNECTIONS="${OPTARG}"	;;
			"*"	)	usage;exit 1		;;
		esac
	done

	if [[ -z "${LINK}" ]]
	then
		printf '%s\n' "ard must be run with option -l."
		printf '%s\n' "See \`ard -h\` for more information."
	fi
}

set_args() {
	if [[ -z "${DIR}" ]]
	then
		DIR="$(pwd)"
	elif [[ ! -d "${DIR}" ]]
	then
		printf '%s\n' "Directory does not exist."
		printf '%s\n' "Do you want to create the directory? (y/n)" 
		read -r  yn
		case "${yn}" in
			[Yy]*	)	mkdir -p "${DIR}"	;;
			[Nn]*	)	exit 1			;;
			"*"	)	exit 1			;;
		esac
	fi

	if [[ -z "${CONNECTIONS}" ]]
	then
		X=""
	else
		X="-x ${CONNECTIONS}"
	fi

	IFS=' ' read -r -a LINKS <<< "${LINK}"
}

download() {
	for i in "${LINKS[@]}"
	do
		aria2c -q -d "${DIR}" "${X}" "$i" &
	done
}

main() {
	get_args "$@"
	set_args
	download
	exit 0
}

main "$@"
