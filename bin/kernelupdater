#!/usr/bin/env sh

set -e

sudo -v
cd /usr/src/linux
zcat /proc/config.gz | sudo tee /usr/src/linux/.config
sudo make olddefconfig
if [ "$1" = "-e" ]
then
	sudo make menuconfig
fi
sudo make modules_prepare
sudo make -j4
sudo make modules_install
echo "Moving kernel..."
sudo mv arch/x86/boot/bzImage /boot/EFI/Gentoo/bzImage
echo "Kernel moved."
