#!/usr/bin/env bash

set -e
[[ $EUID -ne 0 ]] && { echo Run this script as root; exit 1; }

time {
	echo cd /usr/src/linux
	cd /usr/src/linux || { echo "failed to cd into /usr/src/linux"; exit 1; }
	
	echo make clean
	make clean || { echo "failed make clean"; exit 1; }
	
	echo "zcat /proc/config.gz > /usr/src/linux/.config"
	zcat /proc/config.gz > /usr/src/linux/.config
	
	echo make olddefconfig
	make olddefconfig
	
	[[ "$1" = "-e" ]] && { echo make menuconfig; make menuconfig; }
	
	echo make -j4
	make -j4 || exit 1
	
	echo mv arch/x86/boot/bzImage /boot/EFI/Gentoo/bzImage 
	mv arch/x86/boot/bzImage /boot/EFI/Gentoo/bzImage || \
		{ echo failed to move kernel to /boot/EFI/Gentoo/bzImage; exit 1; }
}
