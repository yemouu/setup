#!/usr/bin/env bash

set -e
[[ $EUID -ne 0 ]] && { echo Run this script as root; exit 1; }
cd /usr/src/linux
make clean
zcat /proc/config.gz > /usr/src/linux/.config
make olddefconfig
echo Updated old config for new kernel.
[[ "$1" = "-e" ]] && { make menuconfig; echo Kernel config edited; }
make modules_prepare
echo Kernel modules prepared
make -j4
echo Kernel compiled
make modules_install
echo Kernel modules installed
mv arch/x86/boot/bzImage /boot/EFI/Gentoo/bzImage
echo Moved kernel to EFI partition
