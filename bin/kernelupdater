#!/usr/bin/env sh

set -e

sudo -v
if ! [ "$(id -u)" = 0 ]
then
	echo "Run this script as root"
	exit 1
fi

if [ "$1" = "-e" ]
then
	edit_kernel=true
else
	edit_kernel=false
fi

cd /usr/src/linux
sudo zcat /proc/config.gz > /usr/src/linux/.config
sudo make olddefconfig
if [ $edit_kernel = true ]
then
	sudo make menuconfig
fi
sudo make modules_prepare
sudo make -j4
sudo make modules_install
echo "Moving kernel..."
sudo mv arch/x86/boot/bzImage /boot/EFI/Gentoo/bzImage
echo "Kernel moved."
