#!/usr/bin/env bash

prompt="powermenu"
options="poweroff\\nreboot\\nfake-sleep\\nsleep\\nhibernate\\nhybrid-sleep"

confirm() {
	local prompt="Are you sure? [$input]"
	local input
	input="$(printf "yes\\nno" | rofi -dmenu -i -p "$prompt")"
	case $input in
		Y*|y*	) return 0 ;;
		N*|n*	) exit 0 ;;
		*	) exit 1 ;;
	esac
}

sleep_task() {
	mpc -q pause
	pactl set-source-mute @DEFAULT_SOURCE@ true
	pactl set-sink-mute @DEFAULT_SINK@ true
	while true
	do
		if [[ $(dunstify -b -t 0 -a "powermenu" "Speakers Muted" "Click here to unmute") = 2 ]]
		then
			pactl set-sink-mute @DEFAULT_SINK@ false
			exit 0
		fi
	done
}

input=$(printf '%b' "$options" | rofi -dmenu  -i -p "$prompt")
case $input in
	poweroff	) confirm; alacritty -e sudo openrc-shutdown -p now ;;
	reboot		) confirm; alacritty -e sudo openrc-shutdown -r now ;;
	sleep		) confirm; sleep_task & sleep 0.5 && xset dpms force off ;;
	hibernate	) confirm; sleep_task & alacritty -e loginctl hibernate -i ;;
	hybrid-sleep	) confirm; sleep_task & alacritty -e loginctl hybrid-sleep -i ;;
	*		) exit 1 ;;
esac
