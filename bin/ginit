#!/usr/bin/env bash

[[ $# -eq 0 ]] && { echo "${0##*/} requires an argument."; exit 1; }
sxhkdm_setup() {
	[[ -L "${HOME}/.config/sxhkd/sxhkdm-default.sxhkdrc" ]] && rm "${HOME}/.config/sxhkd/sxhkdm-default.sxhkdrc" || echo "Failed to delete sxhkdm-default.sxhkdrc"
	ln -s "${HOME}/.config/sxhkd/$1.sxhkdrc" "${HOME}/.config/sxhkd/sxhkdm-default.sxhkdrc"
}

case $1 in
	bspwm|bsp ) sxhkdm_setup bspwm; exec xinit bspwm ;;
	herbstluftwm|herbstluft|hlwm ) exec xinit herbstluftwm ;;
	openbox|ob ) sxhkdm_setup bare; exec xinit openbox ;;
	sway ) exec "${HOME}/.autostart" wayland &
		exec sway ;;
	* ) echo "No entry for $1." ;;
esac
