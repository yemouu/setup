#!/usr/bin/env bash

password_file="${HOME}/.steampw"
silent_mode="-silent"
account_number=1

check_steam() { pgrep steam &> /dev/null; }
close_steam() { check_steam && steam -shutdown; }

if [[ $# -ge 1 ]]
then
	for i in "$@"
	do
		case $i in
			close ) close_steam; exit 0 ;;
			kill ) check_steam && { pkill -9 steam; exit 0; } ;;
			dev ) developer_mode="-dev" ;;
			nosilent ) unset silent_mode ;;
			check ) if check_steam
				then
					notify-send -a "steamy" -t 4000 "Steam is running"
					exit 0
				else
					notify-send -a "steamy" -t 4000 "Steam isn't running"
					return 1
				fi
				;;
			* ) account_number=$i ;;
		esac
	done
fi

. "$password_file"
close_steam
username="steam_un$account_number"
password="steam_pw$account_number"
exec steam $silent_mode $developer_mode -login "${!username}" "${!password}"
