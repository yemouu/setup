#!/usr/bin/env sh

# . "${HOME}/.cache/wal/colors.sh"

reload_dunst() {
	if pidof dunst > /dev/null
	then
		pkill dunst
	fi
}

reload_bspwm() {
	if pidof bspwm > /dev/null
	then
		"${HOME}/.config/bspwm/bspwmrc" &
	fi
}

reload_herbstluftwm() {
	if pidof herbstluftwm > /dev/null
	then
		herbstclient reload &
	fi
}

main() {
	reload_dunst &
	reload_bspwm &
	reload_herbstluftwm &
}

main
