#!/usr/bin/env sh

# shellcheck source=/home/yemou/.cache/wal/colors.sh
 . "${HOME}/.cache/wal/colors.sh"

reload_dunst() {
	if pidof dunst > /dev/null
	then
		killall dunst
	fi
}

reload_bspwm() {
	"${HOME}/.config/bspwm/bspwmrc" &
}

reload_herbstluftwm() {
	herbstclient reload &
}

main() {
	reload_dunst &
	#reload_bspwm &
	reload_herbstluftwm &
}

main

