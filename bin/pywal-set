#!/usr/bin/env sh

# shellcheck source=/home/yemou/.cache/wal/colors.sh
 . "${HOME}/.cache/wal/colors.sh"

reload_dunst() {
	killall dunst
	dunst \
		-lb "${color0}" \
		-nb "${color0}" \
		-cb "${color0}" \
		-lf "${color7}" \
		-bf "${color7}" \
		-cf "${color7}" \
		-nf "${color7}" \
		-lfr "${color8}" \
		-nfr "${color4}" \
		-cfr "${color1}" \
		 > "${HOME}/.config/dunst/log" 2>&1 &
}

reload_bspwm() {
	"${HOME}/.config/bspwm/bspwmrc" &
}

reload_herbstluftwm() {
	herbstclient reload &
}

main() {
	reload_dunst &
	#reload_bspwm &
	reload_herbstluftwm &
}

main

