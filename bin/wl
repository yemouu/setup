#!/usr/bin/env bash

XDG_SESSION_TYPE=wayland

QT_QPA_PLATFORM=wayland-egl
QT_WAYLAND_FORCE_DPI=physical

SDL_VIDEODRIVER=wayland

MOZ_ENABLE_WAYLAND=1

export XDG_SESSION_TYPE QT_QPA_PLATFORM QT_WAYLAND_FORCE_DPI SDL_VIDEODRIVER MOZ_ENABLE_WAYLAND

{
    exec mpd &
    exec syncthing -no-browser &> "${XDG_CACHE_HOME}/syncthing-log" &
    exec parsecd app_daemon=1:app_silent=1:hidden=1 &

    exec "${HOME}/doc/setup/noti/music/music-changed" &
} &
case $1 in
    sway|s ) exec sway ;;
esac
