#!/usr/bin/env bash

[[ -f /tmp/sxhkdm.lock ]] && {
	echo "sxhkdm is locked"
	exit 1
}

echo lock > /tmp/sxhkdm.lock

if [[ -n $XDG_CONFIG_HOME ]]
then
	sxhkd_cfg_dir="${XDG_CONFIG_HOME}/sxhkd"
else
	sxhkd_cfg_dir="${HOME}/.config/sxhkd"
fi

if [[ -n "$1" ]]
then
	if [[ -L "${sxhkd_cfg_dir}/sxhkdrc" && -f "${sxhkd_cfg_dir}/$1" ]]
	then
		rm "${sxhkd_cfg_dir}/sxhkdrc"
	elif [[ ! -f "${sxhkd_cfg_dir}/$1" ]]
	then
		echo "${sxhkd_cfg_dir}/$1 is not found"
		exit 1
	elif [[ -e "${sxhkd_cfg_dir}/sxhkdrc" && ! -L "${sxhkd_cfg_dir}/sxhkdrc" ]]
	then
		echo "sxhkdrc is not a symbolic link"
		exit 1
	fi
	ln -s "${sxhkd_cfg_dir}/$1" "${sxhkd_cfg_dir}/sxhkdrc"
fi

if pgrep -xf "sxhkd -c ${sxhkd_cfg_dir}/base.sxhkdrc" &> /dev/null
then
	pkill -USR1 -xf "sxhkd -c ${sxhkd_cfg_dir}/base.sxhkdrc"
else
	sxhkd -c "${sxhkd_cfg_dir}/base.sxhkdrc" &
fi

if pgrep -xf "sxhkd" &> /dev/null
then
	pkill -USR1 -xf "sxhkd"
else
	sxhkd &
fi

rm /tmp/sxhkdm.lock
