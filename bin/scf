#!/usr/bin/env sh

DELETE=false
CONTINUE=false
ME=false

usage() { printf '%s' " 
Usage: scf [OPTION] [-u [USER] | -m | -d]

Example: scf -cu yeemou
	 scf -d

Options
	-d	Deletes contents of music folder.

	-c	Continues download if a file is already found.

	-u 	Picks user to download likes from. The end of soundcloud url.
		Ex: 'scf -u yeemou' will target https://soundcloud.com/yeemou

	-m	Downloads from user specified in ~/.config/scdl/scdl.cfg

	-h	Displays this message

"
}

get_arguments() {
	while getopts "dcu:hm" OPTION; do
		case "$OPTION" in
			"d"	)	DELETE=true		;;
			"c"	)	CONTINUE=true		;;
			"u"	)	USERNAME="${OPTARG}"	;;
			"h"	)	usage; exit 0		;;
			"m"	)	ME=true			;;
			"*"	)	usage; exit 1		;;
		esac
	done

	if [ -z "${USERNAME}" ] && [ "${DELETE}" = false ] && [ ${ME} = false ]
	then
		echo "scf must be run with -d -m or -u."
		echo "Run scf -h for more information"
		exit 1
	fi
}

clean() {
	if ! command -v xdg-user-dir > /dev/null
	then
		DIRECTORY="${HOME}/Music"
	elif [ "$(xdg-user-dir MUSIC)" != "${HOME}" ]
	then
		DIRECTORY="$(xdg-user-dir MUSIC)"
	fi

	if [ "${DELETE}" = true ]; then
		rm "${DIRECTORY}/"* 2> /dev/null
		echo "${DIRECTORY} is cleared"
	fi
}

download() {
	if [ -z "${USERNAME}" ] && [ ${ME} = false ]
	then
		exit 1
	elif [ "${CONTINUE}" = true ] && [ ! -z "${USERNAME}" ]
	then
		scdl \
			-l "https://soundcloud.com/${USERNAME}" \
			-fc --download-archive "${DIRECTORY}/archive" \
			--onlymp3 --path "${DIRECTORY}" --addtofile
	elif [ ${CONTINUE} = false ] && [ ! -z "${USERNAME}" ]
	then
		scdl \
			-l "https://soundcloud.com/${USERNAME}" \
			-f --download-archive "${DIRECTORY}/archive" \
			--onlymp3 --path "${DIRECTORY}" --addtofile
	elif [ ${CONTINUE} = true ] && [ ${ME} = true ]
	then
		scdl \
			-fc --download-archive "${DIRECTORY}/archive" \
			--onlymp3 --path "${DIRECTORY}" --addtofile me
	elif [ ${CONTINUE} = false ] && [ ${ME} = true ]
	then
		scdl \
			-f --download-archive "${DIRECTORY}/archive" \
			--onlymp3 --path "${DIRECTORY}" --addtofile me
	fi
}

main() {
	get_arguments "$@"
	clean
	download
}

main "$@"
