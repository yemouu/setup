#!/usr/bin/env bash

# Wrapper for Pywal
# Requires:
#	pywal

usage() { printf '%s' "
Usage: pywal [OPTION] -w [WALL]

Options:
	-w	Wallpaper number.
		Looks for walpapers in XDG_PICTURES_DIR/wallpapers

	-l	Creates Light Colorscheme

	-b	Picks a backend
		Options: colorthief colorz haishoku schemer2 wal[default]

	-s	Sets color saturation. From 0.0-1.0

	-t	Sets a theme

	-h	Displays this message
"
}

get_args() {

	while getopts "w:b:ls:t:h" OPT
	do
		case ${OPT} in
			w	) WALL_NUM="${OPTARG}"		;;
			b	) BACKEND="${OPTARG}"		;;
			l	) LIGHT="-l"			;;
			s	) SATURATION="${OPTARG}"	;;
			t	) THEME="${OPTARG}"		;;
			h	) usage;exit 0			;;
			*	) usage;exit 1			;;
		esac
	done

	if [ -z "${WALL_NUM}" ] && [ -z "${THEME}" ]
	then
		echo "pywal must be run with option -w"
		echo "Run pywal -h for more information"
		exit 1
	fi
}

exec_wal() {
	if [ -z "${WALL_NUM}" ] && [ -z "${THEME}" ]
	then
		echo "Wallpaper not found"
		exit 1
	elif [ -n "$SATURATION" ]
	then
		wal --backend "${BACKEND}" --saturate "$SATURATION" ${LIGHT} \
			-ct -i \
			"$(xdg-user-dir PICTURES)/wallpapers/Wall-${WALL_NUM}."*
	elif [ -n "${THEME}" ]
	then
		wal --theme "${THEME}" ${LIGHT}
	else
		wal --backend "${BACKEND}" ${LIGHT} -ct -i \
			"$(xdg-user-dir PICTURES)/wallpapers/Wall-${WALL_NUM}."*
	fi
}

main() {
	BACKEND="wal"
	LIGHT=""

	get_args "$@"
	exec_wal
	pywal-set
	exit 0
}

main "$@"
