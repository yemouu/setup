#!/usr/bin/env sh

# Wrapper for Pywal
# Requires:
#	pywal

usage() {
cat << EOF

Usage: pywal [OPTION] -w [WALL]

Options:
	-w	Wallpaper number.
		Looks for walpapers in XDG_PICTURES_DIR/wallpapers

	-l	Creates Light Colorscheme

	-b	Picks a backend
		Options: colorthief colorz haishoku schemer2 wal[default]

	-s	Sets color saturation. From 0.0-1.0

	-h	Displays this message

EOF
}

get_args() {

	while getopts "w:b:ls:h" OPT
	do
		case ${OPT} in
			w	) WALL_NUM="${OPTARG}"		;;
			b	) BACKEND="${OPTARG}"		;;
			l	) LIGHT="-l"			;;
			s	) SATURATION="${OPTARG}"	;;
			h	) usage;exit 0			;;
			*	) usage;exit 1			;;
		esac
	done

	if [ -z "${WALL_NUM}" ]
	then
		echo "pywal must be run with option -w"
		echo "Run pywal -h for more information"
		exit 1
	fi
}

exec_wal() {
	if [ -z "${WALL_NUM}" ]
	then
		echo "Wallpaper not found"
		exit 1
	elif [ ! -z "$SATURATION" ]
	then
		wal --backend "${BACKEND}" --saturate "$SATURATION" ${LIGHT} \
			-ct -i \
			"$(xdg-user-dir PICTURES)/wallpapers/Wall-${WALL_NUM}."*
	else
		wal --backend "${BACKEND}" ${LIGHT} -ct -i \
			"$(xdg-user-dir PICTURES)/wallpapers/Wall-${WALL_NUM}."*
	fi
}

main() {
	BACKEND="wal"
	LIGHT=""

	get_args "$@"
	exec_wal
	pywal-set
	exit 0
}

main "$@"
