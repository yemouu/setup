#!/usr/bin/env bash

info() {
	case $1 in
		f) msg="fail"; color="\e[31;1m";;
		i) msg="info"; color="\e[32;1m";;
		w) msg="warn"; color="\e[33;1m";;
	esac
	shift
	printf "\n${color}%s\e[m %s\n\n" "[${msg}]" "$*"
}

usage() { printf '%s' "usage: ${0##*/} [options]
	-a: requires confirmation to update and remove packages
	-c: removes orphaned packages
	-h: displays usage statement
	-r: regenerates ebuild cache
	-s: skip repository sync
	-u: updates packages
"
}

remove_orphans() {
	info i removing orphans
	command -v emerge &> /dev/null || info w emerge not found
	printf '%s\n' "$ sudo emerge --depclean --verbose $ask"
	sudo emerge --depclean --verbose $ask || { info f failed to remove orphans; exit 1; }
	info i orphans removed
}

regen_cache() {
	info i regenerating ebuild cache
	command -v emerge &> /dev/null || info w emerge not found
	printf '%s\n' "$ sudo emerge --regen --verbose"
	sudo emerge --regen --verbose || { info f failed to regenerate ebuild cache; exit 1; }
	info i ebuild cache regenerated
}

sync_repo() {
	info i syncing repositories
	command -v emaint &> /dev/null || info w emaint not found
	printf '%s\n' "$ sudo emaint sync --auto"
	sudo emaint sync --auto || { info f failed to sync repositories; exit 1;}
	info i repositories synced
}

update_pkgs() {
	info i updating packages
	command -v emerge &> /dev/null || info w emerge not found
	printf '%s\n' "$ sudo emerge --update --deep --newuse --with-bdeps=y --verbose @world $ask"
	sudo emerge --update --deep --newuse --with-bdeps=y --verbose @world $ask || \
		{ info f failed to update packages; exit 1; }
	info i packages updated
}

upd_sync_repos=true
upd_regen_cache=false
upd_update_pkgs=false
upd_remove_orphans=false

[[ -z $* ]] && { sync_repo; exit 0; }
for (( a=1; a<$(( ${#@} + 1 )); a++ ))
do
	arg=${!a}
	[[ ! $arg =~ ^-.* || ${#arg} -lt 2 ]] && continue
	for (( i=1; i<${#arg}; i++ ))
	do
		case ${arg:$i:1} in
			a ) ask="--ask" ;;
			c ) upd_remove_orphans=true ;;
			h ) usage; exit 0 ;;
			r ) upd_regen_cache=true ;;
			s ) upd_sync_repos=false ;;
			u ) upd_update_pkgs=true ;;
			* ) printf '%s\n' "${0##*/}: -${a:$i:1} is an invalid argument"; usage; exit 1 ;;
		esac
	done
done

[[ $upd_sync_repos = true ]] && sync_repo
[[ $upd_regen_cache = true ]] && regen_cache
[[ $upd_update_pkgs = true ]] && update_pkgs
[[ $upd_remove_orphans = true ]] && remove_orphans
