#!/usr/bin/env bash

upd_pypi3=false
upd_gentoo_repos=false
upd_gentoo_mirrors=false
upd_git_repos=false

upd_git_repos_dir="${HOME}/doc/git"

usage() { printf '%s' "
Usage: upd [OPTIONS]

Options:
	-h	displays this message
	-p	enables pip package updates
	-g	enables gentoo repos sync
	-G	enables git repo updating

"
}

get_args() {
	while getopts "hpplgGm" OPTS
	do
		case $OPTS in
			h ) usage;exit 0 ;;
			p ) upd_pypi3=true ;;
			g ) upd_gentoo_repos=true ;;
			G ) upd_git_repos=true ;;
			* ) usage;exit 1;;
		esac
	done
	if [[ $upd_pypi3 = false && $upd_gentoo_repos = false && \
		$upd_git_repos = false && $upd_gentoo_mirrors = false ]]
	then
		echo "Nothing selected for updates"
		exit 1
	fi
}

pypi3() {
	if [[ "$upd_pypi3" = false ]] 
	then 
		return 0
	fi

	if ! command -v pip3 > /dev/null
	then
		echo "pip3 not found"
		return 1
	fi

	echo "Updating pip packages..."
	pkgs=$(pip list -o --user --disable-pip-version-check --format=freeze \
		| cut -d'=' -f1)

	# shellcheck disable=SC2086
	pip3 install -U --disable-pip-version-check \
		--user $pkgs 2> /dev/null 

	echo "Done."
}

gentoo_repos() {
	if [[ "$upd_gentoo_repos" = false ]]
	then
		return 0
	fi

	if ! command -v emerge > /dev/null
	then
		echo "emerge not found"
		return 1
	fi

	echo "Updating Gentoo Repository..."
	sudo emaint sync -A
	if command -v eix > /dev/null
	then
		sudo cp -a /var/cache/eix/portage.eix \
			/var/cache/eix/previous.eix
		sudo eix-update
		sudo eix-remote update
	fi
	echo "Done."
}

git_repos() {
	if [[ "$upd_git_repos" = false ]]
	then
		return 0
	fi

	if ! command -v git > /dev/null
	then
		echo "git not found"
		return 1
	fi

	echo "Upadting Git Repositories..."
	dirs="$(find "$upd_git_repos_dir" -name ".git" | sed 's/.....$//g')"
	for repo in $dirs
	do
		git -C "$repo" pull
		echo "Repo Updated..."
	done
	echo "Done."
}

main() {
	if [[ "$(id -u)" = 0 ]]
	then
		echo "Do not run this script as root."
		exit 1
	fi

	get_args "$@"

	#if [[ $upd_gentoo_repos = true ]]
	#then
	#	sudo -v
	#fi

	git_repos
	pypi3
	gentoo_repos
}

main "$@"
