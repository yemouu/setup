#!/usr/bin/env bash

script_name=${0##*/}
site="https://0x0.st"

usage() { printf '%s' "
Usage: $script_name [-f <file>] [-s <url>] [-u <url>] [input]
OPTIONS:
	-h|--help	displays this message
	-f|--file	file to upload
	-s|--shorten	url to shorten
	-u|--url	url to upload

"
}

upload_stdin() {
	while read -r lines 
	do 
		echo "$lines"
	done | curl -sF"file=@-" $site | xclip -sel clip 
}

upload_file() {
	curl -sF"file=@$1" $site | xclip -sel clip
}

shorten_url() {
	curl -sF"shorten=$1" $site | xclip -sel clip
}

upload_url() {
	curl -sF"url=$1" $site | xclip -sel clip
}

if [[ -f $1 || $# -lt 1 ]]
then
	operation="default"
else
	operation=$1
	shift
fi

case "$operation" in
	default	)
		if [[ $# -gt 0 ]]
		then
			upload_file "$@"
		else
			upload_stdin "$@" 
		fi ;;
	-f|--file ) upload_file "$@" ;;
	-s|--shorten ) shorten_url "$@" ;;
	-u|--url ) upload_url "$@" ;;
	-h|--help ) usage;exit 0 ;;
esac
