#!/usr/bin/env bash

rofi_prompt="Launch a Game"
game_list="----Steam----
BRAIN / OUT
BattleBlock Theater
Clustertruck
Counter-Strike: Global Offensive
Garry's Mod
Golf With Your Friends
Hollow Knight
Insurgency
Metro 2033
Metro: Last Light Redux
Never Split the Party
Plague Inc: Evolved
Portal
Portal 2
Rocket League
ShellShock Live
Starbound
Starbound - Unstable
Stardew Valley
Stick Fight
Terraria
The Escapists 2
Tower Unite
Unturned
scram
----Other----
AssaultCube
Minecraft (MultiMC)
Unreal Tournament
Warsow
Xonotic
"
# Steam
check_steam() {
	if ! pidof steam &> /dev/null
	then
		notify-send -a "Game Launch" "Steam isn't running." "Not starting game."
		exit 1;
	fi
}

battleblock_theater()		{ check_steam && exec steam steam://rungameid/238460; }
brain_out()			{ check_steam && exec steam steam://rungameid/578310; }
clustertruck()			{ check_steam && exec steam steam://rungameid/397950; }
csgo()				{ check_steam && exec steam steam://rungameid/730; }
gmod()				{ check_steam && exec steam steam://rungameid/4000; }
golf_with_your_friends()	{ check_steam && exec steam steam://rungameid/431240; }
hollow_knight()			{ check_steam && exec steam steam://rungameid/367520; }
insurgency()			{ check_steam && exec steam steam://rungameid/222880; }
metro_2033()			{ check_steam && exec steam steam://rungameid/286690; }
metro_last_light_redux()	{ check_steam && exec steam steam://rungameid/287390; }
never_split_the_party()		{ check_steam && exec steam steam://rungameid/711810; }
plague_inc_evolved()		{ check_steam && exec steam steam://rungameid/246620; }
portal()			{ check_steam && exec steam steam://rungameid/400; }
portal_2()			{ check_steam && exec steam steam://rungameid/620; }
rl()				{ check_steam && exec steam steam://rungameid/252950; }
scram()				{ check_steam && exec steam steam://rungameid/773920; }
shellshock_live()		{ check_steam && exec steam steam://rungameid/326460; }
starbound()			{ check_steam && exec steam steam://rungameid/211820; }
starbound_unstable()		{ check_steam && exec steam steam://rungameid/367540; }
stardew_valley()		{ check_steam && exec steam steam://rungameid/413150; }
stick_fight()			{ check_steam && exec steam steam://rungameid/674940; }
terraria()			{ check_steam && exec steam steam://rungameid/105600; }
the_escapists_2()		{ check_steam && exec steam steam://rungameid/641990; }
tower_unite()			{ check_steam && exec steam steam://rungameid/394690; }
unturned()			{ check_steam && exec steam steam://rungameid/304930; }
# Other
assaultcube() 			{ exec "${HOME}/apps/games/AssaultCube/assaultcube.sh"; }
multimc()			{ exec "${HOME}/apps/games/MultiMC/MultiMC"; }
unreal_tournament()		{ exec "${HOME}/apps/games/UnrealTournament/LinuxNoEditor/Engine/Binaries/Linux/UE4-Linux-Shipping" UnrealTournamentc; }
warsow()			{ exec "${HOME}/apps/games/warsow/warsow"; }
xonotic()			{ exec "${HOME}/apps/games/Xonotic/xonotic-linux-sdl.sh"; }

game=$(printf '%b' "$game_list" | rofi -dmenu -i -p "$rofi_prompt")
case $game in
	# Steam
	"BRAIN / OUT"				) brain_out ;;
	"BattleBlock Theater"			) battleblock_theater ;;
	"Clustertruck"				) clustertruck ;;
	"Counter-Strike: Global Offensive"|csgo ) csgo ;;
	"Garry's Mod"|gmod			) gmod ;;
	"Golf With Your Friends"		) golf_with_your_friends ;;
	"Hollow Knight"				) hollow_knight ;;
	"Insurgency"				) insurgency ;;
	"Metro 2033"				) metro_2033 ;;
	"Metro: Last Light Redux"		) metro_last_light_redux ;;
	"Never Split the Party"			) never_split_the_party ;;
	"Plague Inc: Evolved"			) plague_inc_evolved ;;
	"Portal 2"				) portal_2 ;;
	"Portal"				) portal ;;
	"Rocket League"|rl			) rl ;;
	"ShellShock Live"			) shellshock_live ;;
	"Starbound - Unstable"			) starbound_unstable ;;
	"Starbound"				) starbound ;;
	"Stardew Valley"			) stardew_valley ;;
	"Stick Fight"				) stick_fight ;;
	"Terraria"				) terraria ;;
	"The Escapists 2"			) the_escapists_2 ;;
	"Tower Unite"				) tower_unite ;;
	"Unturned"				) unturned ;;
	"scram"					) scram ;;
	# Other
	"AssaultCube"				) assaultcube ;;
	"Minecraft (MultiMC)"			) multimc ;;
	"Unreal Tournament"			) unreal_tournament ;;
	"Warsow"				) warsow ;;
	"Xonotic"				) xonotic ;;
	*					) exit 1 ;;
esac
