:root{
    --ColAppBG: #{bg_color};
    --ColBackground1: var(--ColAppBG);
    --ColBackground2: #{color8};
    --ColAccent: #{color9};
    --ColAccentAlpha: rgba({color9.rgb},0.1);
    --ColAnchor: #{color4};
    --ColLastMessage: transparent;
    --ColFalse: #{color1};
    --ColTrue: #{color2};
    --DisplayEmbedPill: none;
    --DisplayNoConnectionBackdraw: none;
    --FontFamily: sans-serif;
    --FontMonoFamily: monospace;
    --ColTextSelection: rgba({color9.rgb},0.2);
    --ColTooltip: var(--ColAccent);
    --FilterNoHover: grayscale(60%);
    --WidthGuildMax: 80px;
    --SizeEmote: 50px;
    --DisplayNoDoubleBorderRadius: Block;
    --ColFont: #{color15};
    --ColFontBright: #{color0};
    --DisplayBlockedUserMessage: none;
}

.timestampCozy-2hLAPV {
    color: var(--ColFont)!important;
    opacity: 0.5;
}

.dividerEnabled-2TTlcf {
    border-bottom-color: var(--ColFont)!important;
    opacity: 0.03;
}
