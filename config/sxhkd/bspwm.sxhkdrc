super + {alt,ctrl} + Escape
	{$HOME/.config/bspwm/bspwmrc,bspc quit}

super + shift + {s,t,f}
	bspc node -t {floating,tiled,fullscreen}
super + {h,j,k,l}
	bspc node -f {west,south,north,east}
super + {Left,Down,Up,Right}
	bspc node -f {west,south,north,east}
super + {_,alt +} z
	bspc node -f {prev,next}.local
super + {_,shift +} q
	bspc node -{c,k}
super + {_,shift +} {1-9,0}
	bspc {desktop -f,node -d} '^{1-9,10}'

super + m
	sxhkdm mpd.sxhkdrc
