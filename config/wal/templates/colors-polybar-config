[colors]
color0 = {color0}
color1 = {color1}
color2 = {color2}
color3 = {color3}
color4 = {color4}
color5 = {color5}
color6 = {color6}
color7 = {color7}
color8 = {color8}

[bar/bar1]
override-redirect = true
fixed-center = true

width = 80%
height = 28
offset-x = 10%
offset-y = 0.75% 

background = ${{colors.color0}}
foreground = ${{colors.color7}}

border-size = 2
border-color = ${{colors.color0}}

module-margin = 2

font-0 = monospace:size=8;2
font-1 = FontAwesome:size=12;3

modules-left = speakers microphone
modules-center = workspaces
modules-right = time date

wm-restack = bspwm

[bar/bar2]
override-redirect = true
bottom = true
fixed-center = true

width = 80%
height = 28
offset-x = 10%
offset-y = 0.75% 

background = ${{colors.color0}}
foreground = ${{colors.color7}}

border-size = 2
border-color = ${{colors.color0}}

module-margin = 2

font-0 = monospace:size=8;2
font-1 = FontAwesome:size=12;3
font-2 = Noto Sans Mono CJK TC Regular:size=8;2
font-3 = Noto Sans Mono CJK KR Regular:size=8;2
font-4 = Noto Sans Mono CJK JP Regular:size=8;2
font-5 = Noto Sans Mono CJK SC Regular:size=8;2
font-6 = Noto Color Emoji:scale=12;2

modules-left = window-title
modules-center = random-text
modules-right = mpd

wm-restack = bspwm

[module/speakers]
type = internal/pulseaudio

sink = alsa_output.pci-0000_00_1f.3.analog-stereo

format-volume = <label-volume>
format-volume-background = ${{colors.color7}}
format-volume-foreground = ${{colors.color0}}
format-volume-underline = ${{colors.color1}}
format-volume-prefix = "    "
format-volume-prefix-background = ${{colors.color1}}
format-volume-prefix-foreground = ${{colors.color7}}
label-volume = "  %percentage%%  "

format-muted = <label-muted>
format-muted-background = ${{colors.color7}}
format-muted-foreground = ${{colors.color0}}
format-muted-prefix = "    "
format-muted-prefix-background = ${{colors.color1}}
format-muted-prefix-foreground = ${{colors.color7}}
label-muted = "  Mute  "

;[module/microphone]
;type = custom/text
;content = place holder

[module/workspaces]
type = internal/bspwm

enable-click = false
enable-scroll = false

label-focused = "  %name%  "
label-focused-background = ${{colors.color2}}
label-focused-foreground = ${{colors.color7}}

label-occupied = "  %name%  "
label-occupied-background = ${{colors.color7}}
label-occupied-foreground = ${{colors.color0}}

label-urgent = "  %name%  "
label-urgent-background = ${{colors.color5}}
label-urgent-foreground = ${{colors.color7}}

label-empty =

[module/time]
type = internal/date
interval = 1.0

format = <label>
format-background = ${{colors.color7}}
format-foreground = ${{colors.color0}}
format-prefix = "    "
format-prefix-background = ${{colors.color3}}
format-prefix-foreground = ${{colors.color7}}

time = %H:%M
label = "  %time%  "

[module/date]
type = internal/date
interval = 1.0

format = <label>
format-background = ${{colors.color7}}
format-foreground = ${{colors.color0}}
format-prefix = "    "
format-prefix-background = ${{colors.color4}}
format-prefix-foreground = ${{colors.color7}}

date = %a %e %b %Y
label = "  %date%  "

[module/window-title]
type = internal/xwindow

format = <label>
format-background = ${{colors.color7}}
format-foreground = ${{colors.color0}}
format-prefix = "    "
format-prefix-background = ${{colors.color5}}
format-prefix-foreground = ${{colors.color7}}

label = "  %title%  "
label-maxlen = 95
label-empty = "  uwu  "

[module/random-text]
type = custom/text
content = "  uwu  "
content-background = ${{colors.color7}}
content-foreground = ${{colors.color0}}

[module/mpd]
type = internal/mpd
interval = 1.0

host = 127.0.0.1
port = 6600

format-online = <label-song>
format-online-background = ${{colors.color7}}
format-online-foreground = ${{colors.color0}}
format-online-prefix = "    "
format-online-prefix-background = ${{colors.color6}}
format-online-prefix-foreground = ${{colors.color7}}

format-offline = <label-offline>
format-offline-background = ${{colors.color7}}
format-offline-foreground = ${{colors.color0}}
format-offline-prefix = "    "
format-offline-prefix-background = ${{colors.color6}}
format-offline-prefix-foreground = ${{colors.color7}}

format-playing-prefix = "    "
format-playing-prefix-background = ${{colors.color6}}
format-playing-prefix-foreground = ${{colors.color7}}

format-paused-prefix = "    "
format-paused-prefix-background = ${{colors.color6}}
format-paused-prefix-foreground = ${{colors.color7}}

format-stopped = "  MPD Stopped  "
format-stopped-prefix = "    "
format-stopped-prefix-background = ${{colors.color6}}
format-stopped-prefix-foreground = ${{colors.color7}}

label-song = "  %artist% - %title%  "
label-offline = "  MPD Offline  "

[settings]
screenchange-reload = true

[global/wm]
margin-top = 0
margin-bottom = 0

; vim:ft=dosini
