[colors]
color0 = {color0}
color1 = {color1}
color2 = {color2}
color3 = {color3}
color4 = {color4}
color5 = {color5}
color6 = {color6}
color7 = {color7}
color8 = {color8}

[bar/bar1]
override-redirect = true
fixed-center = true

width = 80%
height = 32
offset-x = 10%
offset-y = 0.75% 

background = ${{colors.color0}}
foreground = ${{colors.color7}}

border-size = 0
border-color = ${{colors.color0}}

module-margin = 2

font-0 = monospace:size=8;2
font-1 = FontAwesome:size=12;3
font-2 = Noto Sans Mono CJK TC Regular:size=8;2
font-3 = Noto Sans Mono CJK KR Regular:size=8;2
font-4 = Noto Sans Mono CJK JP Regular:size=8;2
font-5 = Noto Sans Mono CJK SC Regular:size=8;2
font-6 = Noto Color Emoji:scale=12;2

modules-left = workspaces random-text 
modules-center = mpd
modules-right = time date

wm-restack = bspwm

[module/workspaces]
type = internal/bspwm

enable-click = false
enable-scroll = false

label-focused = "  %name%  "
label-focused-background = ${{colors.color0}}
label-focused-foreground = ${{colors.color7}}

label-occupied = "  %name%  "
label-occupied-background = ${{colors.color0}}
label-occupied-foreground = ${{colors.color8}}

label-urgent = "  %name%  "
label-urgent-background = ${{colors.color8}}
label-urgent-foreground = ${{colors.color7}}

label-empty =

[module/time]
type = internal/date
interval = 1.0

format = <label>
format-background = ${{colors.color0}}
format-foreground = ${{colors.color2}}
format-prefix = ""
format-prefix-background = ${{colors.color0}}
format-prefix-foreground = ${{colors.color2}}

time = %H:%M
label = "  %time%  "

[module/date]
type = internal/date
interval = 1.0

format = <label>
format-background = ${{colors.color0}}
format-foreground = ${{colors.color3}}
format-prefix = ""
format-prefix-background = ${{colors.color0}}
format-prefix-foreground = ${{colors.color3}}

date = %a %e %b %Y
label = "  %date%  "

[module/mpd]
type = internal/mpd
interval = 1.0

host = 127.0.0.1
port = 6600

format-online = <label-song>
format-online-background = ${{colors.color0}}
format-online-foreground = ${{colors.color1}}
format-online-prefix = ""
format-online-prefix-background = ${{colors.color0}}
format-online-prefix-foreground = ${{colors.color1}}

format-offline = <label-offline>
format-offline-background = ${{colors.color0}}
format-offline-foreground = ${{colors.color1}}
format-offline-prefix = ""
format-offline-prefix-background = ${{colors.color0}}
format-offline-prefix-foreground = ${{colors.color1}}

format-playing-prefix = ""
format-playing-prefix-background = ${{colors.color0}}
format-playing-prefix-foreground = ${{colors.color1}}

format-paused-prefix = ""
format-paused-prefix-background = ${{colors.color0}}
format-paused-prefix-foreground = ${{colors.color1}}

format-stopped = "  MPD Stopped  "
format-stopped-prefix = ""
format-stopped-prefix-background = ${{colors.color0}}
format-stopped-prefix-foreground = ${{colors.color1}}

label-song = "  %artist% - %title%  "
label-offline = "  MPD Offline  "

label-song-maxlen = 65
label-song-ellipsis = true

[settings]
screenchange-reload = true

[global/wm]
margin-top = 0
margin-bottom = 0

; vim:ft=dosini
