<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc" xmlns:xi="http://www.w3.org/2001/XInclude">
	<resistance>
		<strength>0</strength>
		<screen_edge_strength>0</screen_edge_strength>
	</resistance>
	<focus>
		<focusNew>yes</focusNew>
		<followMouse>no</followMouse>
		<focusLast>yes</focusLast>
		<underMouse>no</underMouse>
		<focusDelay>200</focusDelay>
		<raiseOnFocus>no</raiseOnFocus>
	</focus>
	<placement>
		<policy>Smart</policy>
		<center>yes</center>
		<monitor>Primary</monitor>
		<primaryMonitor>1</primaryMonitor>
	</placement>
	<theme>
		<name>theme</name>
		<titleLayout></titleLayout>
		<keepBorder>yes</keepBorder>
		<animateIconify>no</animateIconify>
		<font place="ActiveWindow">
			<name>monospace</name>
			<size>8</size>
			<weight>bold</weight>
			<slant>normal</slant>
		</font>
		<font place="InactiveWindow">
			<name>monospace</name>
			<size>8</size>
			<weight>bold</weight>
			<slant>normal</slant>
		</font>
		<font place="MenuHeader">
			<name>monospace</name>
			<size>8</size>
			<weight>normal</weight>
			<slant>normal</slant>
		</font>
		<font place="MenuItem">
			<name>monospace</name>
			<size>8</size>
			<weight>normal</weight>
			<slant>normal</slant>
		</font>
		<font place="ActiveOnScreenDisplay">
			<name>monospace</name>
			<size>8</size>
			<weight>bold</weight>
			<slant>normal</slant>
		</font>
		<font place="InactiveOnScreenDisplay">
			<name>monospace</name>
			<size>8</size>
			<weight>bold</weight>
			<slant>normal</slant>
		</font>
	</theme>
	<desktops>
		<number>10</number>
		<firstdesk>1</firstdesk>
		<names>
			<name>1</name>
			<name>2</name>
			<name>3</name>
			<name>4</name>
			<name>5</name>
			<name>6</name>
			<name>7</name>
			<name>8</name>
			<name>9</name>
			<name>0</name>
		</names>
		<popupTime>0</popupTime>
	</desktops>
	<resize>
		<drawContents>yes</drawContents>
		<popupShow>Never</popupShow>
		<popupPosition>Center</popupPosition>
		<popupFixedPosition>
			<x>10</x>
			<y>10</y>
		</popupFixedPosition>
	</resize>
	<margins>
		<top>16</top>
		<bottom>16</bottom>
		<left>16</left>
		<right>16</right>
	</margins>
	<keyboard>
		<chainQuitKey>w-g</chainQuitKey>
		<keybind key="W-z">
			<action name="NextWindow">
				<dialog>none</dialog>
				<bar>no</bar>
				<raise>yes</raise>
				<linear>yes</linear>
				<interactive>no</interactive>
			</action>
		</keybind>
		<keybind key="W-A-z">
			<action name="PreviousWindow">
				<dialog>none</dialog>
				<bar>no</bar>
				<raise>yes</raise>
				<linear>yes</linear>
				<interactive>no</interactive>
			</action>
		</keybind>
		<keybind key="W-h">
			<action name="DirectionalTargetWindow">
				<direction>west</direction>
				<raise>yes</raise>
			</action>
		</keybind>
		<keybind key="W-j">
			<action name="DirectionalTargetWindow">
				<direction>south</direction>
				<raise>yes</raise>
			</action>
		</keybind>
		<keybind key="W-k">
			<action name="DirectionalTargetWindow">
				<direction>north</direction>
				<raise>yes</raise>
			</action>
		</keybind>
		<keybind key="W-l">
			<action name="DirectionalTargetWindow">
				<direction>east</direction>
				<raise>yes</raise>
			</action>
		</keybind>
		<keybind key="W-Left">
			<action name="DirectionalTargetWindow">
				<direction>west</direction>
				<raise>yes</raise>
			</action>
		</keybind>
		<keybind key="W-Down">
			<action name="DirectionalTargetWindow">
				<direction>south</direction>
				<raise>yes</raise>
			</action>
		</keybind>
		<keybind key="W-Up">
			<action name="DirectionalTargetWindow">
				<direction>north</direction>
				<raise>yes</raise>
			</action>
		</keybind>
		<keybind key="W-Right">
			<action name="DirectionalTargetWindow">
				<direction>east</direction>
				<raise>yes</raise>
			</action>
		</keybind>
