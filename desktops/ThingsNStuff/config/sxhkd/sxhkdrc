XF86AudioNext
	mpc next;${HOME}/.dotfiles/global/noti/musicnoti
XF86AudioPlay
	mpc toggle;${HOME}/.dotfiles/global/noti/musicnoti
XF86AudioPrev
	mpc prev;${HOME}/.dotfiles/global/noti/musicnoti
XF86AudioStop
	mpc stop;${HOME}/.dotfiles/global/noti/musicnoti
XF86Mail
	${HOME}/.dotfiles/global/noti/musicnoti

shift + XF86AudioRaiseVolume
	pactl set-sink-volume @DEFAULT_SINK@ 100%;${HOME}/.dotfiles/global/noti/volumenoti
XF86AudioRaiseVolume
	pactl set-sink-volume @DEFAULT_SINK@ +2%;${HOME}/.dotfiles/global/noti/volumenoti
XF86AudioLowerVolume
	pactl set-sink-volume @DEFAULT_SINK@ -2%;${HOME}/.dotfiles/global/noti/volumenoti
XF86AudioMute
	pactl set-sink-mute @DEFAULT_SINK@ toggle;${HOME}/.dotfiles/global/noti/volumenoti
XF86Tools
	${HOME}/.dotfiles/global/noti/volumenoti

alt + shift + XF86AudioRaiseVolume
	pactl set-source-volume @DEFAULT_SOURCE@ 100%;${HOME}/.dotfiles/global/noti/volumenoti
alt + XF86AudioRaiseVolume
	pactl set-source-volume @DEFAULT_SOURCE@ +2%;${HOME}/.dotfiles/global/noti/volumenoti
alt + XF86AudioLowerVolume
	pactl set-source-volume @DEFAULT_SOURCE@ -2%;${HOME}/.dotfiles/global/noti/volumenoti
super + e
	pactl set-source-mute @DEFAULT_SOURCE@ toggle;${HOME}/.dotfiles/global/noti/volumenoti

Print
	nougat -fc
super + Print
	nougat -c

super + Return
	urxvtc
super + b
	firefox
super + d
	Discord
super + r
	rofi -show run
super + w
	rofi -show window
super + t
	${HOME}/.dotfiles/global/noti/timedatenoti

super + Escape
	pkill -USR1 -x sxhkd
super + ctrl + Escape
	bspc quit

super + Tab
	bspc desktop -l next
super + shift + {t,s,f}
	bspc node -t {tiled,floating,fullscreen}

super + {_,shift + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}
super + ctrl + {h,j,k,l}
	bspc node -p {west,south,north,east}

super + ctrl + {1-9}
	bspc node -o 0.{1-9}
super + ctrl + space
	bspc node -p cancel
super + ctrl + shift + space
	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

super + {u,i,o,p}
	bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}
super + shift + {u,i,o,p}
	bspc node -z {right -20 0,top 0 20,bottom 0 -20,left 20 0}

super + {_,ctrl + }q
	bspc node -{c,k}

super + shift + s
	bspc node -g sticky

super + {_,shift + }{1-5}
	bspc {desktop -f,node -d} '^{1-5}'

super + {Left,Down,Up,Right}
	bspc node -v {-20 0,0 20,0 -20,20 0}
