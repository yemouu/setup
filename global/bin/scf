#!/usr/bin/env sh

# Wrapper for SCDL
# Requires:
#	scdl - Downloading the music

DELETE=false
CONTINUE=false

usage() { 
cat << EOF

Usage: scf [OPTION] -u [USER]

Example: scf -ku yeemou
	 scf -c

Options
	-d	Deletes contents of music folder.

	-c	Continues download if a file is already found.

	-u 	Picks user to download likes from. The end of soundcloud url.
		Ex: 'scf -u yeemou' will target https://soundcloud.com/yeemou

	-h	Displays this message

EOF
}

get_arguments() {
	while getopts "dcu:h" OPTION; do
		case "$OPTION" in
			"d"	)	DELETE=true		;;
			"c"	)	CONTINUE=true		;;
			"u"	)	USERNAME="${OPTARG}"	;;
			"h"	)	usage; exit 0		;;
			"*"	)	usage; exit 1		;;
		esac
	done

	if [ -z "${USERNAME}" ] && [ "${DELETE}" = false ]; then
		echo "scf must be run with -c or -u."
		echo "Run scf -h for more information"
		exit 1
	fi
}

clean() {
	if [ "$(xdg-user-dir MUSIC)" != "${HOME}" ]; then
		DIRECTORY="$(xdg-user-dir MUSIC)"
	else
		DIRECTORY="${HOME}/Music"
	fi

	if [ "${DELETE}" = true ]; then
		rm "${DIRECTORY}/"* &> /dev/null
		echo "${DIRECTORY} is cleared"
	fi
}

download() {
	if [ -z "${USERNAME}" ]; then
		exit
	else
		if [ "${CONTINUE}" = true ]; then
			scdl \
				-l "https://soundcloud.com/${USERNAME}" \
				-fc --download-archive "${DIRECTORY}/archive" \
				--onlymp3 --path "${DIRECTORY}" --addtofile
		else
			scdl \
				-l "https://soundcloud.com/${USERNAME}" \
				-f --download-archive "${DIRECTORY}/archive" \
				--onlymp3 --path "${DIRECTORY}" --addtofile
		fi
	fi
}

main() {
	get_arguments "$@"
	clean
	download
}

main "$@"
