#!/usr/bin/env bash

# Download music from SoundCloud
# Requires:
#	scdl - Downloading the music

CLEAN=false
KEEP_GOING=false

usage() { 
cat << EOF

Usage: scf [OPTION] -u [USER]

Example: scf -ku yeemou
	 scf -c

Options
	-d	Deletes contents of music folder.

	-c	Continues download if a file is already found.

	-u 	Picks user to download likes. The end of soundcloud url.
		Ex: 'scf -u yeemou' will targethttps://soundcloud.com/yeemou

	-h	Displays this message

EOF
}

get_arguments() {
	while getopts "dcu:h" OPTION
	do
		case "$OPTION" in
			"d"	)	CLEAN=true		;;
			"c"	)	KEEP_GOING=true		;;
			"u"	)	USERNAME="${OPTARG}"	;;
			"h"	)	usage; exit 1		;;
			"*"	)	usage; exit 1		;;
		esac
	done

	if [ -z "${USERNAME}" ] && [ "${CLEAN}" = false ]
	then
		echo "scf must be run with -c or -u."
		echo "Run scf -h for more information"
		exit 1
	fi
}

clean() {
	if [ "$(xdg-user-dir MUSIC)" != "${HOME}" ]
	then
		DIRECTORY="$(xdg-user-dir MUSIC)"
	else
		DIRECTORY="${HOME}/Music"
	fi

	if [ "${CLEAN}" = true ]
	then
		rm "${DIRECTORY}"/* &> /dev/null
		echo "${DIRECTORY} is cleared"
	fi
}

download() {
	if [ -z ${USERNAME} ]
	then
		exit
	else
		if [ "${KEEP_GOING}" = true ]
		then
			scdl \
				-l "https://soundcloud.com/${USERNAME}" \
				-fc --download-archive "${DIRECTORY}/archive" \
				--onlymp3 --path "${DIRECTORY}"
		else
			scdl \
				-l "https://soundcloud.com/${USERNAME}" \
				-f --download-archive "${DIRECTORY}/archive" \
				--onlymp3 --path "${DIRECTORY}"
		fi
	fi
}

main() {
	get_arguments "$@"
	clean
	download
}

main "$@"
