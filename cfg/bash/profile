[ ! $USER = "ye" ] || [ ! $SHELL = "/bin/bash" ] && return

PATH="${HOME}/bin:$PATH"
XDG_DATA_HOME="${HOME}/data"
XDG_CONFIG_HOME="${HOME}/cfg"
XDG_CACHE_HOME="${HOME}/tmp/cache"

ALTERNATE_EDITOR=""
VISUAL="emacsclient -c"
EDITOR="emacsclient -t"
PAGER="less"

LESSHISTFILE="/dev/null"
HISTFILE="${XDG_CACHE_HOME}/bash_history"
HISTSIZE=
HISTFILESIZE=
HISTCONTROL+="erasedups:ignoreboth"

VDPAU_DRIVER=radeonsi

GNUPGHOME="${XDG_DATA_HOME}/gnupg"
XINITRC="${XDG_CONFIG_HOME}/xorg/xinitrc"
INPUTRC="${XDG_CONFIG_HOME}/bash/inputrc"
PASSWORD_STORE_DIR="${HOME}/doc/.pws"

DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_RUNTIME_DIR}/bus"

export PATH XDG_{DATA,CONFIG,CACHE}_HOME ALTERNATE_EDITOR VISUAL EDITOR PAGER \
       LESSHISTFILE HISTFILE HISTSIZE HISTFILESIZE HISTCONTROL GNUPGHOME XINITRC INPUTRC \
       PASSWORD_STORE_DIR DBUS_SESSION_BUS_ADDRESS

[ -f ${XDG_CONFIG_HOME}/bash/rc  ] && . "${XDG_CONFIG_HOME}/bash/rc"

{ ! pgrep -f 'dbus-daemon --session' && DISPLAY=:0 exec dbus-daemon --session --address="${DBUS_SESSION_BUS_ADDRESS}" --syslog &
! pgrep emacs && exec emacs --daemon &> /dev/null &
} &

clear
